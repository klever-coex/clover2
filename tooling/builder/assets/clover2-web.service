[Unit]
Description=Clover2 Web
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/clover2 # TODO: add ci/cd and generate docker-compose file to /opt/clover2 with fixed tags
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
