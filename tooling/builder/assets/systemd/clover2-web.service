[Unit]
Description=Clover2 Web
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/clover2
ExecStart=/bin/bash -c "HOSTNAME=$(hostname) docker compose up -d"
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
